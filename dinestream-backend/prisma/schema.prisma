generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────
model User {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  password    String
  phone       String?
  role        Role        @default(WAITER)
  status      StaffStatus @default(ON_DUTY)
  shift       String?
  shiftStart  String?
  shiftEnd    String?
  avatarColor String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders      Order[]     @relation("WaiterOrders")

  @@map("users")
}

// ─── Categories ───────────────────────────────────────────────
model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  icon      String?
  color     String?
  createdAt DateTime   @default(now())

  menuItems MenuItem[]

  @@map("categories")
}

// ─── Menu Items ───────────────────────────────────────────────
model MenuItem {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  price       Float
  emoji       String?
  isAvailable Boolean  @default(true)
  prepTime    Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category    @relation(fields: [categoryId], references: [id])
  categoryId  String
  orderItems  OrderItem[]

  @@map("menu_items")
}

// ─── Tables ───────────────────────────────────────────────────
model Table {
  id          String      @id @default(cuid())
  tableNumber Int         @unique
  label       String
  capacity    Int
  status      TableStatus @default(AVAILABLE)
  floor       Int         @default(1)
  zone        String?
  waiter      String?
  duration    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders      Order[]

  @@map("tables")
}

// ─── Orders ───────────────────────────────────────────────────
model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)
  totalAmount Float
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  table       Table       @relation(fields: [tableId], references: [id])
  tableId     String
  waiter      User        @relation("WaiterOrders", fields: [waiterId], references: [id])
  waiterId    String
  items       OrderItem[]

  @@map("orders")
}

// ─── Order Items ──────────────────────────────────────────────
model OrderItem {
  id         String   @id @default(cuid())
  quantity   Int
  unitPrice  Float
  notes      String?
  createdAt  DateTime @default(now())

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String

  @@map("order_items")
}

// ─── Enums ────────────────────────────────────────────────────
enum Role {
  ADMIN
  MANAGER
  WAITER
  CHEF
}

enum StaffStatus {
  ON_DUTY
  ON_BREAK
  OFF_DUTY
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  PENDING
  PREPARING
  SERVED
  PAID
  CANCELLED
}